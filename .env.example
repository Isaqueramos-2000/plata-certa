# Copie este arquivo para .env e preencha os valores.

# URL do backend proxy (deixe vazio para usar a URL de produção padrão).
# Desenvolvimento local: EXPO_PUBLIC_API_URL=http://localhost:3000
EXPO_PUBLIC_API_URL=

# Habilita respostas simuladas sem chamadas reais ao backend.
EXPO_PUBLIC_USE_MOCK=true
