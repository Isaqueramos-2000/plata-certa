# Anthropic API key — usada por services/plantAI.ts.
# IMPORTANTE: variáveis EXPO_PUBLIC_* ficam expostas no bundle do app.
# No MVP web local pode usar direto. Em produção, mova a chamada para
# um backend seu (Cloudflare Worker, Lambda, etc.) e mantenha a chave
# apenas no servidor.
EXPO_PUBLIC_ANTHROPIC_API_KEY=

# Habilita o mock mode: services/plantAI.ts retorna respostas falsas
# sem queimar tokens. Use durante o desenvolvimento de UI.
EXPO_PUBLIC_USE_MOCK=true
