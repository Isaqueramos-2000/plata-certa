# ──────────────────────────────────────────────────────────────────────────────
# PlantaCerta — variáveis de ambiente
# Copie para .env e preencha os valores. Nunca commite o .env real.
# ──────────────────────────────────────────────────────────────────────────────

# URL do backend proxy.
# Desenvolvimento local: rode `vercel dev` e use http://localhost:3000
# Produção: deixe vazio — o app usa https://plata-certa.vercel.app por padrão.
EXPO_PUBLIC_API_URL=

# Modo mock: respostas simuladas sem chamar o backend (útil para dev de UI).
EXPO_PUBLIC_USE_MOCK=true

# ──────────────────────────────────────────────────────────────────────────────
# Firebase — Autenticação Anônima (opcional mas recomendado para produção)
# ──────────────────────────────────────────────────────────────────────────────
#
# Passos para configurar:
#   1. Acesse console.firebase.google.com
#   2. Crie um projeto → adicione um app Web
#   3. Copie o firebaseConfig gerado e preencha abaixo
#   4. Authentication → Sign-in method → habilite "Anônimo"
#   5. Para o backend: Project Settings → Service accounts → Generate new key
#      Cole o JSON como valor de FIREBASE_SERVICE_ACCOUNT no Vercel
#      (vercel env add FIREBASE_SERVICE_ACCOUNT production)
#
# Sem estas variáveis: o app funciona em modo degradado (rate limit por device ID).

EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
